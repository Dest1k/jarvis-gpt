{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis.local/qa/review-packet.schema.json",
  "title": "JARVIS immutable review packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "packet_id",
    "case_id",
    "sanitized_request",
    "expected_contract",
    "actual_output",
    "bounded_evidence",
    "deterministic_failures",
    "recorded_verdict",
    "replayed_verdict",
    "source_record_sha256",
    "source_record_canonical_sha256",
    "source_evidence_sha256",
    "source_manifest_sha256",
    "source_replay_sha256",
    "packet_digest"
  ],
  "properties": {
    "schema": {"const": "jarvis.qa.review-packet.v2"},
    "packet_id": {"type": "string", "minLength": 1},
    "case_id": {"type": "string", "pattern": "^[A-Z0-9](?:[A-Z0-9]|[._-](?=[A-Z0-9])){2,79}$"},
    "sanitized_request": {"type": "object"},
    "expected_contract": {"type": "object"},
    "actual_output": {},
    "bounded_evidence": {"type": "object"},
    "deterministic_failures": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "recorded_verdict": {"enum": ["PASS", "FAIL", "INCONCLUSIVE", "BLOCKED_BY_ENV", "BLOCKED_BY_SPEC", "SKIP", "ERROR"]},
    "replayed_verdict": {"enum": ["PASS", "FAIL", "INCONCLUSIVE", "BLOCKED_BY_ENV", "BLOCKED_BY_SPEC", "SKIP", "ERROR"]},
    "source_record_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "source_record_canonical_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "source_evidence_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "source_manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "source_replay_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "packet_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
