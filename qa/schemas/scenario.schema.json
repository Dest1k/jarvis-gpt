{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis.local/qa/scenario.schema.json",
  "title": "JARVIS assurance scenario",
  "type": "object",
  "additionalProperties": false,
  "required": ["scenario_id", "title", "transport", "request", "expected_contract", "validators"],
  "properties": {
    "scenario_id": {"type": "string", "pattern": "^[A-Z0-9](?:[A-Z0-9]|[._-](?=[A-Z0-9])){2,79}$"},
    "title": {"type": "string", "minLength": 1},
    "transport": {"type": "string", "enum": ["offline", "http", "cli"]},
    "request": {"type": "object"},
    "expected_contract": {"type": "object"},
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {"$ref": "#/$defs/artifact"},
          {"$ref": "#/$defs/canary_absence"},
          {"$ref": "#/$defs/claimed_state"},
          {"$ref": "#/$defs/exit_consistency"},
          {"$ref": "#/$defs/format_contract"},
          {"$ref": "#/$defs/identity"},
          {"$ref": "#/$defs/response_integrity"},
          {"$ref": "#/$defs/stream_integrity"}
        ]
      }
    },
    "required": {"type": "boolean"},
    "semantic_review_required": {"type": "boolean"},
    "skip_reason": {"type": "string", "minLength": 1},
    "tags": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  },
  "allOf": [
    {
      "if": {"required": ["skip_reason"]},
      "then": {"required": ["required"], "properties": {"required": {"const": false}}}
    }
  ],
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "root", "expected_path", "expected_sha256"],
      "properties": {
        "kind": {"const": "artifact"},
        "field": {"type": "string", "minLength": 1},
        "root": {"type": "string", "pattern": "^[a-z][a-z0-9_-]{0,31}$"},
        "expected_path": {"type": "string", "minLength": 1},
        "expected_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "source_root": {"type": "string", "pattern": "^[a-z][a-z0-9_-]{0,31}$"},
        "source_path": {"type": "string", "minLength": 1},
        "source_sha256_before": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "allOf": [
        {
          "if": {
            "anyOf": [
              {"required": ["source_root"]},
              {"required": ["source_path"]},
              {"required": ["source_sha256_before"]}
            ]
          },
          "then": {"required": ["source_root", "source_path", "source_sha256_before"]}
        }
      ]
    },
    "canary_absence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {"const": "canary_absence"},
        "canaries": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    },
    "claimed_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {"const": "claimed_state"},
        "claims_field": {"type": "string", "minLength": 1},
        "observed_field": {"type": "string", "minLength": 1},
        "keys": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "exit_consistency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {"const": "exit_consistency"},
        "process_field": {"type": "string", "minLength": 1},
        "result_field": {"type": "string", "minLength": 1}
      }
    },
    "format_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {"const": "format_contract"},
        "field": {"type": "string", "minLength": 1},
        "exact": {},
        "fullmatch": {"type": "string"},
        "language": {"type": "string", "enum": ["ru", "en"]},
        "allow_mixed_language": {"type": "boolean"},
        "word_count": {"type": "integer", "minimum": 0},
        "line_count": {"type": "integer", "minimum": 0},
        "json": {"const": true},
        "json_schema": {"type": "object"}
      },
      "anyOf": [
        {"required": ["exact"]},
        {"required": ["fullmatch"]},
        {"required": ["language"]},
        {"required": ["word_count"]},
        {"required": ["line_count"]},
        {"required": ["json"]},
        {"required": ["json_schema"]}
      ]
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {"const": "identity"},
        "expected_conversation_id": {"type": "string", "minLength": 1},
        "expected_runtime_id": {"type": "string", "minLength": 1},
        "expected_namespace": {"type": "string", "minLength": 1},
        "forbidden_conversation_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "response_integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {"const": "response_integrity"},
        "field": {"type": "string", "minLength": 1}
      }
    },
    "stream_integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {"const": "stream_integrity"},
        "field": {"type": "string", "minLength": 1},
        "allowed_types": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    }
  }
}
