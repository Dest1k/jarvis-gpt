{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis.local/qa/scenario.schema.json",
  "title": "JARVIS assurance scenario",
  "type": "object",
  "additionalProperties": false,
  "required": ["scenario_id", "title", "transport", "request", "expected_contract", "validators"],
  "allOf": [
    {
      "if": {"required": ["skip_reason"]},
      "then": {"required": ["required"], "properties": {"required": {"const": false}}}
    }
  ],
  "properties": {
    "scenario_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9_.-]{2,79}$"},
    "title": {"type": "string", "minLength": 1},
    "transport": {"enum": ["offline", "http", "cli"]},
    "request": {"type": "object"},
    "expected_contract": {"type": "object"},
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["kind"],
        "properties": {"kind": {"type": "string", "minLength": 1}}
      }
    },
    "required": {"type": "boolean"},
    "semantic_review_required": {"type": "boolean"},
    "skip_reason": {"type": "string", "minLength": 1},
    "tags": {"type": "array", "items": {"type": "string"}}
  }
}
