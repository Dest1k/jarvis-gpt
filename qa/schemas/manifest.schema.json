{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis.local/qa/manifest.schema.json",
  "title": "JARVIS assurance evidence manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "campaign_id",
    "namespace",
    "evidence_file",
    "evidence_sha256",
    "evidence_size",
    "record_count",
    "case_ids",
    "record_sha256s",
    "record_canonical_sha256s",
    "terminal_chain_sha256",
    "counts",
    "exit_code"
  ],
  "properties": {
    "schema": {"const": "jarvis.qa.campaign-manifest.v2"},
    "campaign_id": {"type": "string", "pattern": "^[a-z0-9](?:[a-z0-9]|[._-](?=[a-z0-9])){7,127}$"},
    "namespace": {"type": "string", "pattern": "^[a-z0-9](?:[a-z0-9]|[._-](?=[a-z0-9])){7,127}$"},
    "evidence_file": {"type": "string", "minLength": 1},
    "evidence_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "evidence_size": {"type": "integer", "minimum": 1},
    "record_count": {"type": "integer", "minimum": 1},
    "case_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[A-Z0-9](?:[A-Z0-9]|[._-](?=[A-Z0-9])){2,79}$"}
    },
    "record_sha256s": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
    },
    "record_canonical_sha256s": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
    },
    "terminal_chain_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["PASS", "FAIL", "INCONCLUSIVE", "BLOCKED_BY_ENV", "BLOCKED_BY_SPEC", "SKIP", "ERROR"],
      "properties": {
        "PASS": {"type": "integer", "minimum": 0},
        "FAIL": {"type": "integer", "minimum": 0},
        "INCONCLUSIVE": {"type": "integer", "minimum": 0},
        "BLOCKED_BY_ENV": {"type": "integer", "minimum": 0},
        "BLOCKED_BY_SPEC": {"type": "integer", "minimum": 0},
        "SKIP": {"type": "integer", "minimum": 0},
        "ERROR": {"type": "integer", "minimum": 0}
      }
    },
    "exit_code": {"type": "integer", "minimum": 0, "maximum": 3}
  }
}
