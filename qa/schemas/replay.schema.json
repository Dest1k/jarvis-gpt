{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis.local/qa/replay.schema.json",
  "title": "JARVIS deterministic replay result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "evidence_sha256",
    "manifest_sha256",
    "terminal_chain_sha256",
    "cases",
    "errors",
    "counts",
    "mismatches",
    "exit_code",
    "replay_digest"
  ],
  "properties": {
    "schema": {"const": "jarvis.qa.replay-result.v2"},
    "evidence_sha256": {"type": "string", "pattern": "^(?:[0-9a-f]{64})?$"},
    "manifest_sha256": {"type": "string", "pattern": "^(?:[0-9a-f]{64})?$"},
    "terminal_chain_sha256": {"type": "string", "pattern": "^(?:[0-9a-f]{64})?$"},
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case_id", "recorded_verdict", "replayed_verdict", "deterministic_failures", "source_record_sha256", "source_record_canonical_sha256"],
        "properties": {
          "case_id": {"type": "string", "pattern": "^[A-Z0-9](?:[A-Z0-9]|[._-](?=[A-Z0-9])){2,79}$"},
          "recorded_verdict": {"enum": ["PASS", "FAIL", "INCONCLUSIVE", "BLOCKED_BY_ENV", "BLOCKED_BY_SPEC", "SKIP", "ERROR"]},
          "replayed_verdict": {"enum": ["PASS", "FAIL", "INCONCLUSIVE", "BLOCKED_BY_ENV", "BLOCKED_BY_SPEC", "SKIP", "ERROR"]},
          "deterministic_failures": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "source_record_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "source_record_canonical_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    },
    "errors": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "counts": {"type": "object"},
    "mismatches": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "exit_code": {"type": "integer", "minimum": 0, "maximum": 3},
    "replay_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
