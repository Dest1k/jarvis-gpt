# Backend secrets — copy to backend/.env.local (gitignored) and fill in values.
# Loaded at CLI startup by load_local_env_file(); an explicit shell export always
# wins over this file. Every var below is OPTIONAL — leave blank to disable.

# --- Web search API providers (keyed, captcha-free; used before the HTML scrapers) ---

# Yandex Search API v2 (the Yandex Cloud "AI Studio" API key). BOTH are required:
# the key AND the Cloud folder id (folderId travels in each request body).
# Folder id looks like b1g........ and is the catalog where the key was created.
JARVIS_YANDEX_SEARCH_API_KEY=
JARVIS_YANDEX_SEARCH_FOLDER_ID=

# Other supported search providers (any one is enough):
JARVIS_BRAVE_SEARCH_API_KEY=
JARVIS_TAVILY_API_KEY=
JARVIS_SERPER_API_KEY=

# --- Telegram bot frontend (jarvis.py telegram-bridge) ---
# Chat with the SAME Jarvis agent from your phone. Create a bot via @BotFather (/newbot)
# and paste its token here. TELEGRAM_ALLOWED_CHAT_IDS is your numeric chat id (message
# @userinfobot, or read chat.id from api.telegram.org/bot<token>/getUpdates); comma-separate
# for more than one. The bridge fails closed: it never starts without both, and only answers
# allow-listed private chats.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# --- Self-healing runtime (auto-restart a crashed/hung model dispatcher) ---
# The supervisor probes the dispatcher and restarts it on a crash/OOM (non-zero exit)
# or a hung "running but not serving" container, then alerts you on Telegram (reuses
# the token above). It never restarts a cleanly-stopped (Exited 0) or never-launched
# dispatcher. Defaults are sensible; override only to tune. Enabled by default.
JARVIS_SELF_HEALING_ENABLED=1
JARVIS_SELF_HEALING_INTERVAL_SEC=90
JARVIS_SELF_HEALING_MIN_FAILURES=2
JARVIS_SELF_HEALING_MAX_RESTARTS=3
JARVIS_SELF_HEALING_WINDOW_SEC=1800

# --- Self-replanning missions ---
# An autonomously-run mission that only ran out of its step budget is continued
# automatically (up to MAX_ROUNDS) until it finishes; one that stays genuinely blocked
# is escalated to your phone via Telegram. Enabled by default.
JARVIS_MISSION_SELF_REPLAN_ENABLED=1
JARVIS_MISSION_SELF_REPLAN_MAX_ROUNDS=2
