# Backend secrets — copy to backend/.env.local (gitignored) and fill in values.
# Loaded at CLI startup by load_local_env_file(); an explicit shell export always
# wins over this file. Most values are optional, but `serve` requires a 32+ character
# JARVIS_API_TOKEN while the secure loopback-auth default is enabled.

# --- Backend API authentication ---
# The Windows launcher creates and protects this automatically. Set it explicitly for
# manual `jarvis.py serve` or Docker Compose startup.
JARVIS_API_TOKEN=
JARVIS_API_REQUIRE_TOKEN_ON_LOOPBACK=1

# --- Web search API providers (keyed, captcha-free; used before the HTML scrapers) ---

# Yandex Search API v2 (the Yandex Cloud "AI Studio" API key). BOTH are required:
# the key AND the Cloud folder id (folderId travels in each request body).
# Folder id looks like b1g........ and is the catalog where the key was created.
JARVIS_YANDEX_SEARCH_API_KEY=
JARVIS_YANDEX_SEARCH_FOLDER_ID=

# Other supported search providers (any one is enough):
JARVIS_BRAVE_SEARCH_API_KEY=
JARVIS_TAVILY_API_KEY=
JARVIS_SERPER_API_KEY=

# --- Telegram bot frontend (jarvis.py telegram-bridge) ---
# Chat with the SAME Jarvis agent from your phone. Create a bot via @BotFather (/newbot)
# and paste its token here. Every real user who sends the bot a private message is
# auto-registered with the backend's least-privileged default preset. Generate a separate,
# long random bridge secret (for example: `openssl rand -hex 32`) and set the same value for
# the backend and bridge process. The Windows launcher manages a separate protected runtime
# secret automatically. It must not be the bot token or JARVIS_API_TOKEN.
TELEGRAM_BOT_TOKEN=
JARVIS_TELEGRAM_BRIDGE_SECRET=
# Optional fail-closed bridge assertions. Normally getMe derives bot id and the canonical
# realm `telegram:<bot-id>`; if either assertion is set, both must be set and must match.
JARVIS_TELEGRAM_REALM_ID=
JARVIS_TELEGRAM_BOT_ID=
# During an upgrade, verify the destination bot with getMe, stop the old bridge, and map
# its realm-less DB explicitly. The Windows launcher never infers this value from the token.
# JARVIS_TELEGRAM_LEGACY_REALM_ID=telegram:123456789
# If the old database already used a named realm, identify the exact source separately.
# JARVIS_TELEGRAM_LEGACY_SOURCE_REALM_ID=my-old-bot-realm
# Sessions are refreshed for each Telegram update; keep their residual lifetime short.
JARVIS_TELEGRAM_SESSION_TTL_SECONDS=900
# Persistent fixed-window limits bound guest abuse before LLM/tool work is queued.
JARVIS_TELEGRAM_USER_RATE_LIMIT_PER_MINUTE=30
JARVIS_TELEGRAM_GLOBAL_RATE_LIMIT_PER_MINUTE=1200
JARVIS_API_USER_RATE_LIMIT_PER_MINUTE=240
# Bridge workers are concurrent across users, single-flight per user, and queue-bounded.
JARVIS_TELEGRAM_MAX_CONCURRENT_UPDATES=4
JARVIS_TELEGRAM_MAX_PENDING_UPDATES=64
JARVIS_TELEGRAM_MAX_PENDING_PER_USER=2
JARVIS_TELEGRAM_BRIDGE_RATE_LIMIT_PER_MINUTE=12
# Optional deployment restriction. Empty means registration is open to all private Telegram
# users; otherwise comma-separate immutable numeric Telegram user ids.
TELEGRAM_ALLOWED_CHAT_IDS=
# Non-loopback backend URLs must use HTTPS. Enable only for a trusted container network.
JARVIS_TELEGRAM_ALLOW_INSECURE_BACKEND=0
# Deprecated and ignored compatibility input. Assign owner/admin/user permissions in
# /admin; the bridge never converts this setting into backend authority.
TELEGRAM_OWNER_CHAT_IDS=
# Proactive health/task/screen alerts go only to these already-allowed chats.
# Set this explicitly whenever TELEGRAM_ALLOWED_CHAT_IDS contains multiple users.
TELEGRAM_ALERT_CHAT_IDS=

# --- Speech synthesis ---
# Natural male Russian voice without cinematic/metallic post-processing.
JARVIS_TTS_ENGINE=auto
JARVIS_TTS_SILERO_PACKAGE=v5_5_ru
JARVIS_TTS_SILERO_SPEAKER=aidar
JARVIS_TTS_STYLE=clean
JARVIS_TTS_TEMPO=1.08

# --- Self-healing runtime (auto-restart a crashed/hung model dispatcher) ---
# The supervisor probes the dispatcher and restarts it on a crash/OOM (non-zero exit)
# or a hung "running but not serving" container, then alerts you on Telegram (reuses
# the token above). It never restarts a cleanly-stopped (Exited 0) or never-launched
# dispatcher. Defaults are sensible; override only to tune. Enabled by default.
JARVIS_SELF_HEALING_ENABLED=1
JARVIS_SELF_HEALING_INTERVAL_SEC=90
JARVIS_SELF_HEALING_MIN_FAILURES=2
JARVIS_SELF_HEALING_MAX_RESTARTS=3
JARVIS_SELF_HEALING_WINDOW_SEC=1800
# Grace window after a restart — a big model reloading is not re-probed/re-restarted
# until this many seconds pass (a Qwen-35B warmup easily needs a few minutes).
JARVIS_SELF_HEALING_GRACE_SEC=300

# --- Self-replanning missions ---
# An autonomously-run mission that only ran out of its step budget is continued
# automatically (up to MAX_ROUNDS) until it finishes; one that stays genuinely blocked
# is escalated to your phone via Telegram. Enabled by default.
JARVIS_MISSION_SELF_REPLAN_ENABLED=1
JARVIS_MISSION_SELF_REPLAN_MAX_ROUNDS=2
