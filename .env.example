# Host-side heavy runtime root. Keep models, cache, databases and logs out of git.
JARVIS_HOME=D:\jarvis

# Runtime profiles (RTX 5090 32GB + 128GB RAM):
#   gemma4-turbo      — 26B A4B NVFP4, fastest interactive, no offload
#   gemma4-mono-perf  — 31B IT NVFP4, interactive 31B default (min ~12GB offload, 8k)
#   gemma4-mono       — 31B IT NVFP4, stability/long-context (CPU offload, slow decode)
JARVIS_PROFILE=gemma4-turbo
JARVIS_MODEL_ROOT=D:\jarvis\data\models

# OpenAI-compatible local LLM endpoint. vLLM/Ollama adapters can sit behind this.
JARVIS_LLM_BASE_URL=http://localhost:8001/v1
JARVIS_LLM_MODEL=dispatcher
JARVIS_LLM_ENABLED=1
JARVIS_VLLM_IMAGE=vllm/vllm-openai:v0.23.0
CUDA_VISIBLE_DEVICES=0

# Answer self-check: verify substantive answers/mission reports against the task
# and repair once. Set to 0 to skip the extra critic pass and halve LLM calls.
JARVIS_VERIFY_ANSWERS=1

# Optional remote embeddings for hybrid retrieval. Empty model = pure-Python
# fuzzy vector only (still better than keyword search).
JARVIS_EMBEDDINGS_ENABLED=0
JARVIS_EMBEDDINGS_BASE_URL=http://localhost:8001/v1
JARVIS_EMBEDDINGS_MODEL=

# Optional Search API providers for the Google-like web.answer/web.search path.
# Leave empty to keep DuckDuckGo/Bing/Yandex HTML fallback only.
JARVIS_BRAVE_SEARCH_API_KEY=
JARVIS_TAVILY_API_KEY=
JARVIS_SERPER_API_KEY=

# Claude-owned black-box web_surfer module. The bundled implementation is the
# default; this variable may point to another contract-compatible module.
# Jarvis imports it only inside a resident, process-tree-contained worker.
JARVIS_WEB_SURFER_MODULE=jarvis_gpt.web_surfer
# Optional public JarvisWebSurfer constructor kwargs, for example a reviewed
# resident proxy pool. Keep credential-bearing values in the protected runtime
# environment, never in a committed .env file.
# JARVIS_WEB_SURFER_FACTORY_KWARGS_JSON={"proxies":[],"headless":true}

JARVIS_AUTONOMY_ENABLED=1
JARVIS_TELEMETRY_INTERVAL_SEC=120
JARVIS_HEALTH_INTERVAL_SEC=300
JARVIS_LEARNING_INTERVAL_SEC=600
JARVIS_COGNITION_ENABLED=1
JARVIS_COGNITION_INTERVAL_SEC=300
JARVIS_COGNITION_MAX_TOKENS=512
JARVIS_AUTONOMY_MISSION_INTERVAL_SEC=120

# Backend API.
JARVIS_CORS_ORIGINS=
JARVIS_API_TOKEN=
JARVIS_API_HOST=0.0.0.0
JARVIS_API_PORT=8000
JARVIS_API_REQUIRE_TOKEN_ON_LOOPBACK=0

# Deterministic execution substrate. Roots are separated by the platform path
# separator (semicolon on Windows). Process/network/registry capabilities stay
# disabled unless a strict JSON capability file is configured.
# JARVIS_EXECUTION_ROOTS=D:\jarvis;D:\jarvis-gpt
# JARVIS_EXECUTION_CAPABILITIES_FILE=D:\jarvis\execution-capabilities.json

# Optional exact paths for desktop apps installed outside canonical Windows
# locations. This operator-owned JSON is pinned into the bridge policy; names
# must already belong to the fixed native app allowlist.
# JARVIS_BRIDGE_APP_PATHS_JSON={"code.exe":"D:\\VS Code\\Microsoft VS Code\\Code.exe"}

# Server-side Command Center proxy target. Never expose JARVIS_API_TOKEN as NEXT_PUBLIC_*.
JARVIS_BACKEND_URL=http://127.0.0.1:8000
